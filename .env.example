# Apisto Environment Variables
# Copy this file to .env and adjust values for your setup

# HTTP server port
APISTO_PORT=8080

# PostgreSQL / TimescaleDB connection string
APISTO_DATABASE_URL=postgres://apisto:apisto@localhost:5432/apisto?sslmode=disable

# Mosquitto MQTT broker URL
APISTO_MQTT_BROKER_URL=tcp://localhost:1883

# MQTT client ID for this server instance
APISTO_MQTT_CLIENT_ID=apisto-server

# Days to retain telemetry data (TimescaleDB retention policy)
APISTO_RETENTION_DAYS=30

# Seconds of inactivity before a device is marked offline
APISTO_HEARTBEAT_TIMEOUT=60

# Log level: debug, info, warn, error
APISTO_LOG_LEVEL=info

# CORS allowed origins (comma-separated or *)
APISTO_CORS_ORIGINS=*
